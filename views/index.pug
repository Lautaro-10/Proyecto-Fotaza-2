extends layout.pug

block title
  title Inicio - Fotaza

block content
  main
    section.hero.animate-fade-in
      h1 Captura el momento, comparte la magia.
      p Únete a la comunidad de fotografía más vibrante. Explora, inspírate y muestra tu talento al mundo.
      a.btn-primary(href="/posts") Empezar a explorar
      
    section.gallery-container.animate-fade-in.delay-1
      div.masonry-grid

        div.photo-card
          img(src="/assets/amigos-gatos.jpg" alt="Amigos Gatos")
          div.photo-overlay
            div.photo-info
              h3 Aventura Gatuna
              p @sofi gamer fotos
            div.photo-actions
              button(aria-label="Me gusta")
                i.ph.ph-heart

        div.photo-card
          img(src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80&w=800" alt="Retrato")
          div.photo-overlay
            div.photo-info
              h3 Mirada Profunda
              p @retratos_pro
            div.photo-actions
              button(aria-label="Me gusta")
                i.ph.ph-heart

        div.photo-card
          img(src="https://images.unsplash.com/photo-1511895426328-dc8714191300?auto=format&fit=crop&q=80&w=800" alt="Fotografía callejera")
          div.photo-overlay
            div.photo-info
              h3 Luces de Neón
              p @night_walker
            div.photo-actions
              button(aria-label="Me gusta")
                i.ph.ph-heart

        div.photo-card
          img(src="https://images.unsplash.com/photo-1682687982501-1e58f813222e?auto=format&fit=crop&q=80&w=800" alt="Naturaleza")
          div.photo-overlay
            div.photo-info
              h3 Amanecer en el Lago
              p @nature_lover
            div.photo-actions
              button(aria-label="Me gusta")
                i.ph.ph-heart
 
        div.photo-card
          img(src="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&q=80&w=800" alt="Bosque verde")
          div.photo-overlay
            div.photo-info
              h3 Bosque Encantado
              p @green_life
            div.photo-actions
              button(aria-label="Me gusta")
                i.ph.ph-heart

        div.photo-card
          img(src="https://images.unsplash.com/photo-1501854140801-50d01698950b?auto=format&fit=crop&q=80&w=800" alt="Montañas")
          div.photo-overlay
            div.photo-info
              h3 Aventura
              p @explorer
            div.photo-actions
              button(aria-label="Me gusta")
                i.ph.ph-heart