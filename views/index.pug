extends layout.pug

block title
  title Inicio - Fotaza

block content
  main
    if busqueda
      section.hero.animate-fade-in(style="padding: 2rem 0; text-align: center;")
        h1 Resultados para "#{busqueda}"
        p Encontramos #{publicaciones.length} coincidencias.
        a.btn-primary(href="/") Volver al muro
    else
      section.hero.animate-fade-in
        h1 Captura el momento, comparte la magia.
        p Únete a la comunidad de fotografía más vibrante. Explora, inspírate y muestra tu talento al mundo.
        if !usuarioId
          a.btn-primary(href="/login") Empezar a explorar
      
    section.gallery-container.animate-fade-in.delay-1
      div.masonry-grid(style="max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 2rem;")
        
        if publicaciones && publicaciones.length > 0
          each pub in publicaciones
            div.photo-card(style="border: 1px solid #ddd; background: var(--card-bg); padding: 1.5rem; border-radius: 8px; box-shadow: var(--shadow); width: 100%;")
              
              div(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;")
                div
                  h2(style="margin-bottom: 0.2rem;")= pub.titulo
                  p(style="color: #666; font-size: 0.9rem;")
                    | Por: 
                    strong @#{pub.Usuario ? pub.Usuario.username : 'Usuario Desconocido'}
                    if usuarioId && usuarioId !== pub.id_usuario
                      // Botón Seguir (Formulario)
                      form(action=`/followers/seguir/${pub.id_usuario}` method="POST" style="display: inline-block; margin-left: 10px;")
                        button.btn-secondary(type="submit" style="padding: 0.1rem 0.5rem; font-size: 0.8rem;") Seguir
                
                div(style="background: var(--primary-color); padding: 0.5rem 1rem; border-radius: 20px; font-weight: bold; color: white;")
                  if pub.promedio_estrellas > 0
                    span ⭐ #{pub.promedio_estrellas} / 5
                  else
                    span Sin valoraciones
                    
              p(style="margin-bottom: 1rem;")= pub.descripcion
              
              if pub.Imagens && pub.Imagens.length > 0
                div.galeria-imagenes(style="margin-bottom: 1rem;")
                  each img in pub.Imagens
                    img(src=img.ruta_archivo, alt="Foto", style="width: 100%; height: auto; border-radius: 8px;")
              
              hr(style="border: 0; border-top: 1px solid #eee; margin: 1.5rem 0;")

              if usuarioId
                div(style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1rem;")
                  strong Valora esta foto:
                  form(action=`/posts/${pub.id_publicacion}/valorar` method="POST" style="display: flex; gap: 0.5rem;")
                    select.form_input(name="estrellas" required style="padding: 0.2rem;")
                      option(value="5") ⭐⭐⭐⭐⭐ (5)
                      option(value="4") ⭐⭐⭐⭐ (4)
                      option(value="3") ⭐⭐⭐ (3)
                      option(value="2") ⭐⭐ (2)
                      option(value="1") ⭐ (1)
                    button.btn-primary(type="submit" style="padding: 0.2rem 1rem; font-size: 0.9rem;") Votar

                h3(style="margin-bottom: 1rem; font-size: 1.1rem;") Comentarios (#{pub.Comentarios ? pub.Comentarios.length : 0})
                
                if pub.Comentarios && pub.Comentarios.length > 0
                  div(style="background: #f9f9f9; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; max-height: 200px; overflow-y: auto;")
                    each comentario in pub.Comentarios
                      div(style="margin-bottom: 0.8rem; padding-bottom: 0.8rem; border-bottom: 1px solid #eee;")
                        strong(style="color: var(--primary-color);")= (comentario.Usuario ? comentario.Usuario.nombre : 'Anónimo') + ":"
                        span(style="margin-left: 0.5rem; color: #333;")= comentario.comentario
                else
                  p(style="color: #666; font-style: italic; margin-bottom: 1rem; font-size: 0.9rem;") Nadie ha comentado aún. Sé el primero.
                
                form(action=`/posts/${pub.id_publicacion}/comentar` method="POST" style="display: flex; gap: 0.5rem;")
                  input.form_input(type="text" name="texto_comentario" placeholder="Escribe un comentario..." required style="flex-grow: 1;")
                  button.btn-secondary(type="submit") Comentar
              else
                p(style="text-align: center; color: #888; font-style: italic; font-size: 0.9rem;")
                  a(href="/login" style="color: var(--primary-color); text-decoration: underline;") Inicia sesión
                  |  para valorar y comentar.
                  
        else
          div(style="text-align: center; padding: 4rem 0;")
            h2 ¡La galería está vacía!
            p Sé el primero en compartir una foto con el mundo.