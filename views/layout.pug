doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    block title
      title Fotaza
      
    // Google Fonts
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet")
    // Phosphor Icons
    script(src="https://unpkg.com/@phosphor-icons/web")
    // Custom CSS
    link(rel="stylesheet" href="/css/style.css")
    link(rel="icon" href="./public/assets/icons/col-rizada.png")
    
  body
    header.header
      a.logo(href="/") Fotaza.
      nav.nav-links
        if usuarioId
          a.nav-link(href="/posts") Mis Publicaciones
          a.nav-link(href="/posts/crear") Crear Publicación
          a.nav-link(href="/followers") Mis Seguidores  
          a.nav-link(href="/our_story") Sobre Nosotros
          
      div(style="display: flex; gap: 1rem; align-items: center;")
        if usuarioId
          span(style="color: var(--text-color); font-weight: 500;") ¡Hola, #{usuarioNombre}!
          a.btn-secondary(href="/logout") Cerrar Sesión
        else
          a.btn-primary(href="/login") Entrar
          a.btn-primary(href="/register") Registrarse
          
        button#theme-toggle.theme-toggle(aria-label="Cambiar tema")
          i.ph.ph-moon
        
    block content
        
    footer.footer
      p &copy; 2026 Fotaza. Todos los derechos reservados.
      
    script(src="/js/main.js")
