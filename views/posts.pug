extends layout.pug

block content
  main.hero.animate-fade-in
    h1 Mis Fotos
    p La siguiente página mostrará tus fotos subidas y la interacción de la comunidad.
    
    if publicaciones && publicaciones.length > 0
      each pub in publicaciones
        div(style="border: 1px solid #ccc; background: var(--card-bg); margin-bottom: 2rem; padding: 1.5rem; border-radius: 8px; box-shadow: var(--shadow);")
          
          div(style="display: flex; justify-content: space-between; align-items: center;")
            h2(style="margin-bottom: 0.5rem;")= pub.titulo
            div(style="background: var(--primary-color); padding: 0.5rem 1rem; border-radius: 20px; font-weight: bold; color: white;")
              if pub.promedio_estrellas > 0
                span ⭐ #{pub.promedio_estrellas} / 5
              else
                span Sin valoraciones
                
          p(style="margin-bottom: 1.5rem;")= pub.descripcion
          
          if pub.Imagens && pub.Imagens.length > 0
            div.galeria-imagenes(style="margin-bottom: 1.5rem;")
              each img in pub.Imagens
                img(src=img.ruta_archivo, alt="Mi foto", style="max-width: 100%; border-radius: 8px;")
          
          hr(style="border: 0; border-top: 1px solid #ddd; margin: 1.5rem 0;")

          div(style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1rem;")
            strong ¡Valora esta foto!
            form(action=`/posts/${pub.id_publicacion}/valorar` method="POST")
              select.form_input(name="estrellas" required )
                option(value="5") ⭐⭐⭐⭐⭐ (5)
                option(value="4") ⭐⭐⭐⭐ (4)
                option(value="3") ⭐⭐⭐ (3)
                option(value="2") ⭐⭐ (2)
                option(value="1") ⭐ (1)
              button.btn-primary(type="submit") Votar

          h3(style="margin-bottom: 1rem;") Comentarios (#{pub.Comentarios ? pub.Comentarios.length : 0})
          
          if pub.Comentarios && pub.Comentarios.length > 0
            div(style="background: #f9f9f9; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; max-height: 200px; overflow-y: auto;")
              each comentario in pub.Comentarios
                div(style="margin-bottom: 0.8rem; padding-bottom: 0.8rem; border-bottom: 1px solid #eee;")
                  strong(style="color: var(--primary-color);")= comentario.Usuario.nombre + ":"
                  span(style="margin-left: 0.5rem; color: #333;")= comentario.comentario
          else
            p(style="color: #666; font-style: italic; margin-bottom: 1rem;") Nadie ha comentado aún.
          
          form(action=`/posts/${pub.id_publicacion}/comentar` method="POST")
            input.form_input(type="text" name="texto_comentario" placeholder="Escribe un comentario..." required)
            button.btn-secondary(type="submit") Comentar
              
    else
      div(style="text-align: center; margin-top: 3rem;")
        p(style="font-size: 1.2rem; color: #666;") Aún no has subido ninguna foto.
        a.btn-primary(href="/posts/crear" style="display: inline-block; margin-top: 1rem;") ¡Anímate a crear tu primera publicación!
